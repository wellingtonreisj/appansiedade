# Copie este arquivo para .env e preencha os valores

# Telegram — obtenha em @BotFather
TELEGRAM_BOT_TOKEN=seu_token_aqui

# Seu chat ID — aparece no log quando você manda /start pro bot
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# Anthropic — para OCR de comprovantes (opcional)
ANTHROPIC_API_KEY=sua_chave_aqui

# URL pública do app (após deploy no Railway)
APP_URL=https://seu-app.railway.app

# Caminho do banco (padrão: data.db na raiz)
DB_PATH=data.db
